{
  "extends": "../../packages/config/tsconfig.nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@sge/db": [
        "../../packages/db/src"
      ],
      "@sge/ui": [
        "../../packages/ui/src"
      ],
      "@sge/types": [
        "../../packages/types/src"
      ],
      "@sge/utils": [
        "../../packages/utils/src"
      ]
    },
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
