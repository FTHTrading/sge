# ─────────────────────────────────────────────
# SGE Alignment OS — Environment Configuration
# ─────────────────────────────────────────────

# ── Mainnet RPC ──
# Required for CLI scripts and live chain reads.
# Default: https://eth.llamarpc.com (public, rate-limited)
MAINNET_RPC_URL=https://eth.llamarpc.com

# ── Private Key ──
# Required for live claim test and settlement scripts ONLY.
# Never exposed to the browser. Only used by CLI scripts.
# PRIVATE_KEY=0x_YOUR_WALLET_PRIVATE_KEY_HERE

# ── Contract Addresses (pre-filled — do not change) ──
CLAIM_CONTRACT_ADDRESS=0x4BFeF695a5f85a65E1Aa6015439f317494477D09
SGE_TOKEN_ADDRESS=0x40489719E489782959486A04B765E1e93e5B221a
USDC_TOKEN_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDT_TOKEN_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7

# ── NextAuth.js ──
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-strong-random-secret-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# ── Database (via @sge/db) ──
# Required only for the API route (claim history recording).
# DATABASE_URL=postgresql://user:password@localhost:5432/sge_dev

# ── Demo Mode ──
# Set to "true" to simulate approval/settlement flows without real transactions.
# Set to "false" for live mainnet testing.
NEXT_PUBLIC_DEMO_MODE=true

# ── SGE Legacy Infrastructure (set after deployment) ──
# These addresses are populated by running deploy-sge-distributor.ts.
# Leave empty until contracts are deployed to mainnet.
# SGE_DISTRIBUTOR_ADDRESS=
# SGE_TREASURY_ADDRESS=
# SGE_ACCESS_MANAGER_ADDRESS=

# ── SGE Roles ──
# Admin wallet (defaults to contractOwner from sge.ts if not set)
# SGE_ADMIN_ADDRESS=0x9ffE2f6f306fB9bE0b8b9558fC4B86dc43A39Cb7
# Operator wallet (for OPERATOR_ROLE on Distributor)
# SGE_OPERATOR_ADDRESS=

# ── SGE Claim Settings ──
# Amount of SGE per claim (default: 1000, in whole tokens)
# SGE_CLAIM_AMOUNT=1000
# Funding amount for fund-sge-inventory.ts (default: 10000)
# SGE_FUND_AMOUNT=10000
# Funding target: "distributor" or "vault" (default: distributor)
# SGE_FUND_TARGET=distributor

# ── SGE UI (used by admin pages via NEXT_PUBLIC_*) ──
# NEXT_PUBLIC_SGE_DISTRIBUTOR_ADDRESS=
# NEXT_PUBLIC_SGE_TREASURY_ADDRESS=
# NEXT_PUBLIC_SGE_ACCESS_MANAGER_ADDRESS=
