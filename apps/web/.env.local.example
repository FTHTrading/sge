# NextAuth.js — Required
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-strong-random-secret-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# Database (via @sge/db)
# DATABASE_URL=postgresql://user:password@localhost:5432/sge_dev

# Optional: OAuth providers (add as needed)
# GITHUB_ID=
# GITHUB_SECRET=

# ── Settlement / Wallet Setup ──
# Private key of the funding wallet (for scripts only, never exposed to browser)
# SENDER_PRIVATE_KEY=0x...
# RPC_URL=https://eth.llamarpc.com

# ── Demo Mode ──
# Set to "true" to simulate approval/settlement flows without real transactions
# NEXT_PUBLIC_DEMO_MODE=false
