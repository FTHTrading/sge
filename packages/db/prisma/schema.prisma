// This is your Prisma schema file
// SGE Alignment OS – Full Domain Model

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "jsonProtocol"]
}

// ─────────────────────────────────────────────
// AUTH & IDENTITY
// ─────────────────────────────────────────────

enum Role {
  super_admin
  foundation_admin
  governance_admin
  partner_admin
  partner_user
  certifier
  researcher
  public_viewer
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(public_viewer)
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  accounts     Account[]
  sessions     Session[]
  permissions  Permission[]
  auditEvents  AuditEvent[]
  documents    Document[]
  proofArtifacts ProofArtifact[]
  reports      Report[]

  @@index([email])
  @@index([organizationId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// ORGANIZATION & PARTNERS
// ─────────────────────────────────────────────

enum OrgType {
  foundation
  enterprise
  research
  government
  ngo
  operator
  vendor
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        OrgType  @default(enterprise)
  website     String?
  logoUrl     String?
  description String?  @db.Text
  country     String?
  region      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  partners     Partner[]
  documents    Document[]
  auditEvents  AuditEvent[]

  @@index([slug])
  @@map("organizations")
}

enum PartnerTier {
  strategic
  premier
  standard
  associate
}

enum PartnerStatus {
  active
  pending
  suspended
  inactive
}

model Partner {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  tier           PartnerTier   @default(standard)
  status         PartnerStatus @default(pending)
  joinedAt       DateTime?
  expiresAt      DateTime?
  notes          String?       @db.Text
  contactName    String?
  contactEmail   String?
  region         String?
  commitmentSummary String?    @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  projects         Project[]
  incentivePlans   IncentivePlan[]
  certificationSubmissions CertificationSubmission[]
  auditEvents      AuditEvent[]

  @@index([organizationId])
  @@index([status])
  @@map("partners")
}

// ─────────────────────────────────────────────
// PROJECTS & DEPLOYMENTS
// ─────────────────────────────────────────────

enum ProjectStatus {
  draft
  active
  on_hold
  completed
  cancelled
}

model Project {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?       @db.Text
  region      String?
  country     String?
  status      ProjectStatus @default(draft)
  startDate   DateTime?
  targetDate  DateTime?
  partnerId   String?
  partner     Partner?      @relation(fields: [partnerId], references: [id])
  energyGoalMW Float?
  impactSummary String?     @db.Text
  latitude    Float?
  longitude   Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  deployments  Deployment[]
  milestones   Milestone[]
  documents    Document[]
  auditEvents  AuditEvent[]

  @@index([slug])
  @@index([partnerId])
  @@index([status])
  @@map("projects")
}

enum DeploymentPhase {
  planning
  permitting
  procurement
  construction
  commissioning
  operational
  decommissioned
}

enum ReadinessState {
  not_started
  in_progress
  ready
  blocked
  complete
}

model Deployment {
  id              String          @id @default(cuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id])
  phase           DeploymentPhase @default(planning)
  readinessState  ReadinessState  @default(not_started)
  name            String
  description     String?         @db.Text
  region          String?
  localStakeholders String?       @db.Text
  regulatoryCheckpoints Json?
  plannedStartDate DateTime?
  actualStartDate  DateTime?
  completionDate   DateTime?
  energyOutputMW  Float?
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  milestones  Milestone[]
  auditEvents AuditEvent[]

  @@index([projectId])
  @@index([phase])
  @@map("deployments")
}

// ─────────────────────────────────────────────
// MILESTONES & INCENTIVES
// ─────────────────────────────────────────────

enum MilestoneStatus {
  pending
  in_progress
  completed
  verified
  failed
}

model Milestone {
  id           String          @id @default(cuid())
  name         String
  description  String?         @db.Text
  status       MilestoneStatus @default(pending)
  dueDate      DateTime?
  completedAt  DateTime?
  verifiedAt   DateTime?
  verifiedById String?
  projectId    String?
  project      Project?        @relation(fields: [projectId], references: [id])
  deploymentId String?
  deployment   Deployment?     @relation(fields: [deploymentId], references: [id])
  weight       Float           @default(1.0)
  evidenceNotes String?        @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  incentiveConditions IncentiveCondition[]
  proofArtifacts      ProofArtifact[]
  auditEvents         AuditEvent[]

  @@index([projectId])
  @@index([deploymentId])
  @@index([status])
  @@map("milestones")
}

enum PlanStatus {
  draft
  active
  paused
  completed
  cancelled
}

model IncentivePlan {
  id          String     @id @default(cuid())
  name        String
  description String?    @db.Text
  partnerId   String
  partner     Partner    @relation(fields: [partnerId], references: [id])
  status      PlanStatus @default(draft)
  startDate   DateTime?
  endDate     DateTime?
  notes       String?    @db.Text
  totalUnits  Float?
  claimedUnits Float     @default(0)
  currency    String     @default("USDC")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  conditions  IncentiveCondition[]
  auditEvents AuditEvent[]

  @@index([partnerId])
  @@index([status])
  @@map("incentive_plans")
}

enum ConditionType {
  milestone_completion
  deployment_threshold
  certification_achieved
  date_trigger
  manual_approval
  performance_metric
}

enum ConditionStatus {
  locked
  unlocked
  triggered
  expired
}

model IncentiveCondition {
  id              String          @id @default(cuid())
  planId          String
  plan            IncentivePlan   @relation(fields: [planId], references: [id])
  milestoneId     String?
  milestone       Milestone?      @relation(fields: [milestoneId], references: [id])
  conditionType   ConditionType
  status          ConditionStatus @default(locked)
  description     String?         @db.Text
  threshold       Float?
  units           Float?
  triggerDate     DateTime?
  triggeredAt     DateTime?
  approvedById    String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  auditEvents AuditEvent[]

  @@index([planId])
  @@index([status])
  @@map("incentive_conditions")
}

// ─────────────────────────────────────────────
// STANDARDS & CERTIFICATION
// ─────────────────────────────────────────────

enum StandardStatus {
  draft
  published
  deprecated
  archived
}

model Standard {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  version     String
  description String?        @db.Text
  category    String?
  body        String?        @db.Text
  status      StandardStatus @default(draft)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  certifications CertificationDefinition[]
  auditEvents    AuditEvent[]

  @@index([code])
  @@index([status])
  @@map("standards")
}

model CertificationDefinition {
  id          String   @id @default(cuid())
  standardId  String
  standard    Standard @relation(fields: [standardId], references: [id])
  name        String
  description String?  @db.Text
  criteria    Json?
  scoringModel Json?
  validForDays Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions CertificationSubmission[]

  @@index([standardId])
  @@map("certification_definitions")
}

enum SubmissionStatus {
  draft
  submitted
  under_review
  approved
  rejected
  expired
}

model CertificationSubmission {
  id             String                  @id @default(cuid())
  definitionId   String
  definition     CertificationDefinition @relation(fields: [definitionId], references: [id])
  partnerId      String
  partner        Partner                 @relation(fields: [partnerId], references: [id])
  status         SubmissionStatus        @default(draft)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  expiresAt      DateTime?
  score          Float?
  notes          String?                 @db.Text
  rejectionReason String?                @db.Text
  badge          String?
  evidenceFiles  Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  proofArtifacts ProofArtifact[]
  auditEvents    AuditEvent[]

  @@index([partnerId])
  @@index([definitionId])
  @@index([status])
  @@map("certification_submissions")
}

// ─────────────────────────────────────────────
// GOVERNANCE
// ─────────────────────────────────────────────

enum ProposalStatus {
  draft
  open
  voting
  passed
  rejected
  withdrawn
  implemented
}

model GovernanceProposal {
  id          String         @id @default(cuid())
  title       String
  summary     String?        @db.Text
  body        String?        @db.Text
  status      ProposalStatus @default(draft)
  authorId    String?
  committee   String?
  category    String?
  openedAt    DateTime?
  closedAt    DateTime?
  implementedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  resolutions GovernanceResolution[]
  auditEvents AuditEvent[]

  @@index([status])
  @@map("governance_proposals")
}

enum ResolutionStatus {
  draft
  published
  superseded
  archived
}

model GovernanceResolution {
  id          String           @id @default(cuid())
  proposalId  String
  proposal    GovernanceProposal @relation(fields: [proposalId], references: [id])
  title       String
  body        String?          @db.Text
  status      ResolutionStatus @default(draft)
  version     Int              @default(1)
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  auditEvents AuditEvent[]

  @@index([proposalId])
  @@map("governance_resolutions")
}

// ─────────────────────────────────────────────
// AUDIT / TRUST / PROOF
// ─────────────────────────────────────────────

model AuditEvent {
  id           String   @id @default(cuid())
  eventType    String
  entityType   String
  entityId     String
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id])
  summary      String
  detail       Json?
  ipAddress    String?
  userAgent    String?
  hash         String?
  createdAt    DateTime @default(now())

  // Optional relationship pointers (denormalized for fast lookups)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  partnerId      String?
  partner        Partner?      @relation(fields: [partnerId], references: [id])
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])
  deploymentId   String?
  deployment     Deployment?   @relation(fields: [deploymentId], references: [id])
  milestoneId    String?
  milestone      Milestone?    @relation(fields: [milestoneId], references: [id])
  planId         String?
  plan           IncentivePlan? @relation(fields: [planId], references: [id])
  conditionId    String?
  condition      IncentiveCondition? @relation(fields: [conditionId], references: [id])
  standardId     String?
  standard       Standard?     @relation(fields: [standardId], references: [id])
  submissionId   String?
  submission     CertificationSubmission? @relation(fields: [submissionId], references: [id])
  proposalId     String?
  proposal       GovernanceProposal? @relation(fields: [proposalId], references: [id])
  resolutionId   String?
  resolution     GovernanceResolution? @relation(fields: [resolutionId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@index([eventType])
  @@map("audit_events")
}

model Document {
  id           String   @id @default(cuid())
  name         String
  description  String?
  fileUrl      String?
  fileHash     String?
  mimeType     String?
  sizeBytes    Int?
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])
  entityType   String?
  entityId     String?
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  isPublic     Boolean  @default(false)
  tags         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([uploadedById])
  @@index([entityType, entityId])
  @@map("documents")
}

model ProofArtifact {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  artifactType   String
  fileUrl        String?
  fileHash       String?
  externalUrl    String?
  verifiedAt     DateTime?
  verifiedById   String?
  verifiedBy     User?    @relation(fields: [verifiedById], references: [id])
  milestoneId    String?
  milestone      Milestone? @relation(fields: [milestoneId], references: [id])
  submissionId   String?
  submission     CertificationSubmission? @relation(fields: [submissionId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([milestoneId])
  @@index([submissionId])
  @@map("proof_artifacts")
}

model Report {
  id          String   @id @default(cuid())
  name        String
  reportType  String
  generatedById String?
  generatedBy   User?  @relation(fields: [generatedById], references: [id])
  parameters  Json?
  fileUrl     String?
  status      String   @default("pending")
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([generatedById])
  @@map("reports")
}

model Permission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   String
  action     String
  scope      String?
  grantedById String?
  grantedAt  DateTime @default(now())
  expiresAt  DateTime?

  @@unique([userId, resource, action])
  @@index([userId])
  @@map("permissions")
}

// ─────────────────────────────────────────────
// BLOCKCHAIN / CLAIM INFRASTRUCTURE
// ─────────────────────────────────────────────

model BlockchainNetwork {
  id          String   @id @default(cuid())
  name        String
  chainId     Int      @unique
  rpcUrl      String?
  explorerUrl String?
  isTestnet   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tokenContracts TokenContract[]
  claimContracts ClaimContract[]

  @@index([chainId])
  @@map("blockchain_networks")
}

model TokenContract {
  id          String   @id @default(cuid())
  networkId   String
  network     BlockchainNetwork @relation(fields: [networkId], references: [id])
  symbol      String
  name        String
  address     String
  decimals    Int      @default(6)
  logoUrl     String?
  isSupported Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  claimRules    ClaimRule[]
  allowanceChecks AllowanceCheck[]
  walletClaims  WalletClaim[]

  @@unique([networkId, address])
  @@index([networkId])
  @@map("token_contracts")
}

model ClaimContract {
  id              String   @id @default(cuid())
  networkId       String
  network         BlockchainNetwork @relation(fields: [networkId], references: [id])
  name            String
  address         String
  abi             Json?
  deployedAt      DateTime?
  deployedByWallet String?
  isActive        Boolean  @default(true)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  claimRules    ClaimRule[]
  walletClaims  WalletClaim[]

  @@unique([networkId, address])
  @@index([networkId])
  @@map("claim_contracts")
}

model ClaimRule {
  id              String        @id @default(cuid())
  contractId      String
  contract        ClaimContract @relation(fields: [contractId], references: [id])
  tokenContractId String
  tokenContract   TokenContract @relation(fields: [tokenContractId], references: [id])
  claimAmount     String        // stored as raw token units (BigInt-safe as string)
  claimAmountHuman Float        // human-readable
  isActive        Boolean       @default(true)
  description     String?
  maxClaims       Int?
  totalClaimed    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([contractId])
  @@map("claim_rules")
}

enum ClaimStatus {
  initiated
  approval_pending
  approval_confirmed
  claim_submitted
  claim_confirmed
  failed
  reverted
}

model WalletClaim {
  id              String      @id @default(cuid())
  walletAddress   String
  contractId      String
  contract        ClaimContract @relation(fields: [contractId], references: [id])
  tokenContractId String
  tokenContract   TokenContract @relation(fields: [tokenContractId], references: [id])
  status          ClaimStatus @default(initiated)
  claimAmount     String
  claimAmountHuman Float
  approveTxHash   String?
  claimTxHash     String?
  blockNumber     Int?
  failureReason   String?
  claimedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  logs    TransactionLog[]
  receipt ClaimReceipt?

  @@unique([walletAddress, contractId])
  @@index([walletAddress])
  @@index([contractId])
  @@index([status])
  @@map("wallet_claims")
}

model AllowanceCheck {
  id              String   @id @default(cuid())
  walletAddress   String
  tokenContractId String
  tokenContract   TokenContract @relation(fields: [tokenContractId], references: [id])
  spenderAddress  String
  allowanceRaw    String
  allowanceHuman  Float
  checkedAt       DateTime @default(now())

  @@index([walletAddress])
  @@map("allowance_checks")
}

model TransactionLog {
  id          String   @id @default(cuid())
  claimId     String
  claim       WalletClaim @relation(fields: [claimId], references: [id])
  txType      String
  txHash      String?
  chainId     Int?
  status      String?
  errorMessage String?
  gasUsed     String?
  blockNumber Int?
  loggedAt    DateTime @default(now())

  @@index([claimId])
  @@index([txHash])
  @@map("transaction_logs")
}

model ClaimReceipt {
  id              String   @id @default(cuid())
  claimId         String   @unique
  claim           WalletClaim @relation(fields: [claimId], references: [id])
  walletAddress   String
  tokenSymbol     String
  amountHuman     Float
  amountRaw       String
  approveTxHash   String?
  claimTxHash     String
  blockNumber     Int?
  networkName     String?
  chainId         Int?
  explorerUrl     String?
  issuedAt        DateTime @default(now())

  @@index([walletAddress])
  @@map("claim_receipts")
}
